{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "moderator", "owner"], "description": "The user's role for RBAC." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Character": {
      "title": "Character",
      "description": "An AI character created by a user.",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string", "description": "The UID of the user who created this character." },
        "name": { "type": "string", "description": "The character's name." },
        "avatarUrl": { "type": "string", "format": "uri", "description": "The character's avatar image URL." },
        "greeting": { "type": "string", "description": "The character's initial greeting message." },
        "description": { "type": "string", "description": "Detailed description of the character's persona." },
        "personality": { "type": "string", "description": "The character's personality traits." },
        "visibility": { "type": "string", "enum": ["public", "private", "unlisted"], "description": "Whether the character is public, private, or unlisted." },
        "likesCount": { "type": "number", "description": "The number of likes the character has received." },
        "interactionsCount": { "type": "number", "description": "The number of interactions the character has had." },
        "ratingCount": { "type": "number", "description": "The number of ratings the character has received." },
        "totalRatingScore": { "type": "number", "description": "The sum of all rating scores." },
        "averageRating": { "type": "number", "description": "The average rating score." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the character was created." }
      },
      "required": ["creatorId", "name", "greeting", "description", "visibility", "createdAt", "likesCount", "interactionsCount"]
    },
    "Rating": {
      "title": "Rating",
      "description": "A user's rating for a character.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user." },
        "characterId": { "type": "string", "description": "The ID of the character." },
        "score": { "type": "number", "description": "The rating score (e.g., 1-5)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the rating was given." }
      },
      "required": ["userId", "characterId", "score", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session between a user and a character.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user." },
        "characterId": { "type": "string", "description": "The ID of the character." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the chat was started." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the chat was last updated." }
      },
      "required": ["userId", "characterId", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat session.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string", "description": "The ID of the chat this message belongs to." },
        "role": { "type": "string", "enum": ["user", "model"], "description": "Who sent the message." },
        "content": { "type": "string", "description": "The content of the message." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["chatId", "role", "content", "createdAt"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A specific detail or fact the AI should remember about the chat or characters.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string", "description": "The ID of the chat this memory belongs to." },
        "content": { "type": "string", "description": "The fact or detail to remember." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the memory was added." }
      },
      "required": ["chatId", "content", "createdAt"]
    },
    "Persona": {
      "title": "Persona",
      "description": "A reusable set of personality traits and description.",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string", "description": "The UID of the user who created this persona." },
        "name": { "type": "string", "description": "The persona's name." },
        "description": { "type": "string", "description": "Detailed description of the persona." },
        "personality": { "type": "string", "description": "The persona's personality traits." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the persona was created." }
      },
      "required": ["creatorId", "name", "description", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "A report submitted by a user or moderator.",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string", "description": "The UID of the user who submitted the report." },
        "targetId": { "type": "string", "description": "The ID of the reported character or user." },
        "type": { "type": "string", "enum": ["character", "user"], "description": "The type of entity being reported." },
        "reason": { "type": "string", "description": "The reason for the report." },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"], "description": "The status of the report." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the report was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the report was last updated." }
      },
      "required": ["reporterId", "targetId", "type", "reason", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/characters/{characterId}": {
      "schema": { "$ref": "#/entities/Character" },
      "description": "Stores AI characters."
    },
    "/characters/{characterId}/ratings/{userId}": {
      "schema": { "$ref": "#/entities/Rating" },
      "description": "Stores user ratings for a character."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores chat sessions."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages within a chat."
    },
    "/chats/{chatId}/memories/{memoryId}": {
      "schema": { "$ref": "#/entities/Memory" },
      "description": "Stores specific details the AI should remember."
    },
    "/personas/{personaId}": {
      "schema": { "$ref": "#/entities/Persona" },
      "description": "Stores user-created personas."
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Stores reports submitted by users and moderators."
    }
  }
}
