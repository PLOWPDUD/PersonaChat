{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "displayName_lowercase": { "type": "string", "description": "The user's display name in lowercase for searching." },
        "photoURL": { "type": "string", "description": "The URL to the user's profile photo." },
        "bannerURL": { "type": "string", "description": "The URL to the user's profile banner." },
        "themeColor": { "type": "string", "description": "The user's preferred theme color." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["user", "moderator", "owner"], "description": "The user's role in the application." },
        "level": { "type": "number", "description": "The user's current level." },
        "xp": { "type": "number", "description": "The user's current experience points." },
        "followersCount": { "type": "number", "description": "Number of users following this user." },
        "followingCount": { "type": "number", "description": "Number of users this user is following." },
        "badges": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "A list of badge IDs the user has earned."
        },
        "userPersona": { "type": "string", "description": "A description of the user's persona for AI interactions." },
        "personas": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "A list of custom personas the user has created."
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the profile was last updated." }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Character": {
      "title": "AI Character",
      "description": "Defines an AI personality that users can chat with.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The character's name." },
        "name_lowercase": { "type": "string", "description": "The character's name in lowercase for searching." },
        "avatarUrl": { "type": "string", "description": "The URL to the character's avatar image." },
        "greeting": { "type": "string", "description": "The character's initial greeting message." },
        "description": { "type": "string", "description": "A short description of the character." },
        "personality": { "type": "string", "description": "Detailed instructions for the AI on how to behave as this character." },
        "visibility": { "type": "string", "enum": ["public", "private", "unlisted"], "description": "Who can see and chat with this character." },
        "category": { "type": "string", "description": "The category the character belongs to." },
        "creatorId": { "type": "string", "description": "The UID of the user who created the character." },
        "creatorName": { "type": "string", "description": "The display name of the creator." },
        "likesCount": { "type": "number", "description": "Number of users who favorited this character." },
        "interactionsCount": { "type": "number", "description": "Number of messages sent to this character." },
        "ratingCount": { "type": "number", "description": "Number of ratings received." },
        "totalRatingScore": { "type": "number", "description": "Sum of all rating scores." },
        "averageRating": { "type": "number", "description": "Average rating score." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "greeting", "description", "visibility", "creatorId"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Represents a conversation between a user and one or more characters.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user in the chat." },
        "characterId": { "type": "string", "description": "The primary character's ID (legacy support)." },
        "characterIds": { "type": "array", "items": { "type": "string" }, "description": "List of character IDs in the chat." },
        "characterName": { "type": "string", "description": "Name of the primary character." },
        "characterAvatarUrl": { "type": "string", "description": "Avatar URL of the primary character." },
        "creatorName": { "type": "string", "description": "Creator name of the primary character." },
        "title": { "type": "string", "description": "The title of the chat session." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "characterIds"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat session.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string", "description": "The ID of the chat session." },
        "role": { "type": "string", "enum": ["user", "model"], "description": "The sender's role." },
        "characterId": { "type": "string", "description": "The character ID if the role is 'model'." },
        "content": { "type": "string", "description": "The text content of the message." },
        "imageUrl": { "type": "string", "description": "Optional URL to an image attached to the message." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "role", "content", "createdAt"]
    },
    "Memory": {
      "title": "Chat Memory",
      "description": "A piece of context or memory for a specific chat session.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "content", "createdAt"]
    },
    "Favorite": {
      "title": "User Favorite",
      "description": "A mapping between a user and a character they have favorited.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "characterId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "characterId", "createdAt"]
    },
    "Rating": {
      "title": "Character Rating",
      "description": "A user's rating for a specific character.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "characterId": { "type": "string" },
        "score": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "characterId", "score", "createdAt"]
    },
    "Report": {
      "title": "Content Report",
      "description": "A report filed by a user against a character or message.",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "targetId": { "type": "string" },
        "type": { "type": "string", "enum": ["character", "message"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reporterId", "targetId", "type", "reason", "status", "createdAt"]
    },
    "SiteStats": {
      "title": "Site Statistics",
      "description": "Global statistics for the application.",
      "type": "object",
      "properties": {
        "userCount": { "type": "number" },
        "visitorCount": { "type": "number" }
      }
    },
    "Notification": {
      "title": "User Notification",
      "description": "A notification for a specific user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["character_banned", "character_reviewed", "new_character", "badge_earned"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "characterId": { "type": "string" },
        "badgeId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "title", "message", "read", "createdAt"]
    },
    "GlobalNotification": {
      "title": "Global Notification",
      "description": "A notification for all users.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "characterId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "message", "createdAt"]
    },
    "CommunityPost": {
      "title": "Community Post",
      "description": "A post shared by a user in the PersonaCommunity.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "authorBadges": { "type": "array", "items": { "type": "string" } },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "authorName", "content", "createdAt"]
    },
    "CommunityComment": {
      "title": "Community Comment",
      "description": "A comment on a community post or a reply to another comment.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "parentId": { "type": "string", "description": "The ID of the parent comment if this is a reply." },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "content", "createdAt"]
    },
    "PrivateChat": {
      "title": "Private Chat",
      "description": "A private conversation between users and potentially bots.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["direct", "group"], "description": "The type of chat." },
        "name": { "type": "string", "description": "The name of the group chat." },
        "participants": { "type": "array", "items": { "type": "string" }, "description": "User UIDs in the chat." },
        "characterIds": { "type": "array", "items": { "type": "string" }, "description": "AI Character IDs in the chat." },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["type", "participants", "updatedAt"]
    },
    "PrivateMessage": {
      "title": "Private Message",
      "description": "A single message in a private chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "content", "createdAt"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "A badge or achievement that can be earned.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "xpReward": { "type": "number" }
      },
      "required": ["name", "description", "icon"]
    },
    "Follower": {
      "title": "Follower Relationship",
      "description": "Tracks who follows whom.",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    }
  },
  "firestore": {
    "/profiles/{uid}": { "schema": "Profile", "description": "User profiles." },
    "/characters/{characterId}": { "schema": "Character", "description": "AI characters." },
    "/chats/{chatId}": { "schema": "Chat", "description": "Chat sessions." },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages within a chat." },
    "/chats/{chatId}/memories/{memoryId}": { "schema": "Memory", "description": "Memories for a chat." },
    "/favorites/{favoriteId}": { "schema": "Favorite", "description": "User favorites." },
    "/characters/{characterId}/ratings/{userId}": { "schema": "Rating", "description": "Character ratings." },
    "/reports/{reportId}": { "schema": "Report", "description": "Content reports." },
    "/siteStats/{docId}": { "schema": "SiteStats", "description": "Global site statistics." },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications." },
    "/global_notifications/{notificationId}": { "schema": "GlobalNotification", "description": "Global notifications." },
    "/community_posts/{postId}": { "schema": "CommunityPost", "description": "Community posts." },
    "/community_posts/{postId}/comments/{commentId}": { "schema": "CommunityComment", "description": "Comments on posts." },
    "/community_posts/{postId}/likes/{userId}": { "schema": "object", "description": "Tracking likes on posts." },
    "/users/{userId}/saved_posts/{postId}": { "schema": "object", "description": "Tracking saved posts for users." },
    "/private_chats/{chatId}": { "schema": "PrivateChat", "description": "Private conversations." },
    "/private_chats/{chatId}/messages/{messageId}": { "schema": "PrivateMessage", "description": "Private messages." },
    "/achievements/{achievementId}": { "schema": "Achievement", "description": "Available achievements." },
    "/users/{userId}/achievements/{achievementId}": { "schema": "object", "description": "Earned achievements." },
    "/followers/{followId}": { "schema": "Follower", "description": "Follower relationships." }
  }
}
